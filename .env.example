# Application
APP_NAME=RAG Programming Support System
APP_ENV=development

# Backend
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Ollama local LLM
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b-thinking

# Embedding / Vector storage
VECTOR_DB_PATH=./data/processed/chroma_db
COLLECTION_NAME=programming_sources

# Retrieval settings
TOP_K=5
MIN_RETRIEVAL_SCORE=0.35

# Logging
LOG_LEVEL=INFO
